doctype html
head
  meta(charset='UTF-8')
  title Credit Form
  link(rel='stylesheet' href='/css/creditform.css')
.form-wrapper
  .form-container
    h2 Register new Credit
    form(action='/creditform' method='post')
      label(for='date') Date
      input(type='date' name='date' required='')
      label Customer Name
      input(type='text' name='customerName' required='')

      label Nin 
      input(
          type='text'
          placeholder='CM4900906P76ZE'
          name='Nin'
          pattern='^C[MF][A-Z0-9]{12}$'
          minlength='14'
          maxlength='14'
          oninput='this.value=this.value.toUpperCase()'
          title='Enter a valid Ugandan NIN e.g. CM4900906P76ZE'
          required
       )


      label Phone Number
      input(
            type='text'
            name='phoneNumber'
            placeholder='+256700123456'
            pattern='^\\+256[0-9]{9}$'
            title='Phone number must start with +256 and contain exactly 9 digits after it'
            )
      
      label Address
      input(type='text' name='address')

      label Item Name
      select(name='itemName' required='')
        option(value='')
        option(value='cement') Cement
        option(value='iron_sheetsguage28') Iron Sheets guage28
        option(value='iron_sheetsguage28') Iron Sheets guage32 
        option(value='iron_sheetsguage28') Iron Sheets guage30
      label Quantity
      input(type='number' name='quantity' required='')
      label unitPrice 
      input(type='number' name='unitPrice' required='')
      label Amount deposited
      input(type='number' name='amountDeposited' required='')
      button(type='submit') Save Credit
