doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Sales Dashboard
    link(rel='stylesheet' href='/css/salesdashboard.css')

  body

    .sidebar
      h2 Dashboard
      if isSalesAttendant
        a(href='/salesform') Register New Sale
      a(href='/') Home
      a(href='/logout') Logout
      

    .main-content

      // HEADER
      .header
        h1 SALES DASHBOARD 
      .cards-container
        .card
          h2 Total Sales Today
          p UGX #{todayTotal ? todayTotal.toLocaleString() : '0'}

      .table-section
        h2 Recent Sales

        table
          thead
            tr
              th Item Name
              th Qty
              th Unit Price
              th Customer Name
              th Address
              th Phone
              th Distance
              th Payment
              th Transport
              th Total
              th Date
              th Attendant
              th Action
          tbody
            if dbSales && dbSales.length > 0

              each sale in dbSales
                - const itemNames = sale.items && sale.items.length ? sale.items.map(i => `${i.itemName} (${i.quantity})`).join(', ') : (sale.itemName || 'N/A')
                - const totalQuantity = sale.items && sale.items.length ? sale.items.reduce((sum, i) => sum + (i.quantity || 0), 0) : (sale.quantity || 0)
                - const unitPrice = sale.items && sale.items.length ? sale.items[0].unitPrice : (sale.unitPrice || 0)
                tr
                  td #{itemNames}
                  td #{totalQuantity}
                  td UGX #{(unitPrice).toLocaleString()}
                  td #{sale.customerName}
                  td #{sale.customerAddress}
                  td #{sale.phoneNumber}
                  td #{sale.customerDistance}
                  td #{sale.paymentMethod}
                  td #{sale.transportCharge ? sale.transportCharge.toLocaleString() : '0'}
                  td UGX #{sale.totalCharge ? sale.totalCharge.toLocaleString() : '0'}
                  td #{new Date(sale.date).toLocaleDateString()}
                  td #{sale.attendant ? sale.attendant.fullname : ''}

                  td.actions
                    if isAdmin
                      a.edit-btn(href=`/sale/edit/${sale._id}`) Edit
                    a(href=`/receipt/${sale._id}`) receipt 
                    if isAdmin
                      form(action=`/sale/delete/${sale._id}` method="POST" onsubmit="return confirm('Are you sure you want to delete this sale? This action cannot be undone.');" style="display:inline")
                        button.delete-btn(type="submit") Delete

            else
              tr
                td(colspan="13" style="text-align:center; padding:20px;")
                  | No sales records found.