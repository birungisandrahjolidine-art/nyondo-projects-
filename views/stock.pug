doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Stock Inventory | Nyondo Hardware
    link(rel='stylesheet' href='/css/stock.css')

  body

    // Sidebar
    .sidebar
      h2 Store Manager
      nav
        a(href='/stockdashboard') Dashboard
        if isStoreManager
          a(href='/stockregform') Add New Stock
        a.active(href='/stock') Inventory Levels
        a(href='/logout') Logout

    // Main Content
    .main-content

      header
        h1 Current Inventory
        p Overview of available stock

      // =========================
      // SUMMARY CARDS (FIXED)
      // =========================
      section.stats
        .card
          h3 Total Item Types
          p #{dbStock.length}

        .card
          h3 Total Quantity in Stock
          p
            - let totalQty = dbStock.reduce((sum, item) => sum + item.totalQuantity, 0)
            | #{totalQty}

        .card
          h3 Low Stock Items
          p
            - let lowCount = dbStock.filter(item => item.totalQuantity <= 20).length
            | #{lowCount}

      // =========================
      // LOW STOCK ALERTS (FIXED)
      // =========================
      section.alert-section
        .alert-card
          .alert-header
            span.warning-icon ⚠
            h3 Low Stock Alerts

          ul.alert-list
            - let lowStockItems = dbStock.filter(item => item.totalQuantity <= 20)

            if lowStockItems.length > 0
              each stock in lowStockItems
                li
                  strong #{stock._id}:
                  |  Only #{stock.totalQuantity} units left.
                  span.action-text Reorder soon
            else
              li All items are well stocked 🎉

      // =========================
      // INVENTORY TABLE
      // =========================
      section.table-section
        .table-card
          table
            thead
              tr
                th Item Image
                th Item Name
                th Quantity
                th Selling Price
                th Supplier

            tbody
              if dbStock.length > 0
                each stock in dbStock
                  tr
                    td
                      if stock.itemimage
                        img(
                          src='/uploads/' + stock.itemimage,
                          width='120px',
                          height='120px',
                          style='object-fit: cover; border-radius: 4px;'
                        )
                      else
                        span No Image

                    td #{stock._id}
                    td #{stock.totalQuantity}
                    td UGX #{stock.sellingPrice ? stock.sellingPrice.toLocaleString() : '0'}
                    td #{stock.supplierName || 'N/A'}
              else
                tr
                  td(colspan='5') No stock has been recorded yet