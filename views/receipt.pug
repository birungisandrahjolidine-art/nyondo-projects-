doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Receipt
    link(rel='stylesheet' href='/css/receipt.css')

  body
    .receipt-container

      // HEADER
      .receipt-header
        h2 NYONDO HARDWARE NANSANA UGANDA RECEIPT
        p Thank you for your purchase!

      hr

      // CUSTOMER INFO
      .info
        p
          strong Customer:
          |  #{sale && sale.customerName ? sale.customerName : "N/A"}

        p
          strong Phone:
          |  #{sale && sale.phoneNumber ? sale.phoneNumber : "N/A"}

        p
          strong Address:
          |  #{sale && sale.customerAddress ? sale.customerAddress : "N/A"}

        p
          strong Date:
          |  #{sale && sale.date ? new Date(sale.date).toLocaleDateString() : "N/A"}

      hr

      // ITEM TABLE
      table
          thead
            tr
              th Item
              th Qty
              th Unit Price
              th Total
          tbody
            if sale.items && sale.items.length
              each item in sale.items
                tr
                  td #{item.itemName || 'N/A'}
                  td #{item.quantity || 0}
                  td UGX #{item.unitPrice || 0}
                  td UGX #{item.subTotal || (item.quantity * item.unitPrice) || 0}
            else
              - const item = sale
              - const itemQuantity = item.quantity != null ? item.quantity : 0
              - const itemUnitPrice = item.unitPrice != null ? item.unitPrice : 0
              tr
                td #{item.itemName || 'N/A'}
                td #{itemQuantity}
                td UGX #{itemUnitPrice}
                td UGX #{itemQuantity * itemUnitPrice}

      hr

      // SUMMARY
      .summary
        p
          strong Transport:
          |  #{sale.transportChargeType || 'N/A'}
          if sale.transportCharge > 0
            |  - UGX #{sale.transportCharge}
          else
            |  - Free

        p.total
          strong GRAND TOTAL:
          |  UGX #{sale.totalCharge || 0}

      hr

      // FOOTER
      .footer
        p Thank you for shopping with us!
        p Please come again

      // PRINT BUTTON
      .actions
        button(onclick='window.print()') Print Receipt