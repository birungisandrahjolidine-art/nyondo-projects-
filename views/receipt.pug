doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Receipt
    link(rel='stylesheet' href='/css/receipt.css')

  body
    .receipt-container

      // HEADER
      .receipt-header
        h2 NYONDO HARDWARE NANSANA UGANDA RECEIPT
        p Thank you for your purchase!

      hr

      // CUSTOMER INFO
      .info
        p
          strong Customer:
          |  #{sale && sale.customerName ? sale.customerName : "N/A"}

        p
          strong Phone:
          |  #{sale && sale.phone ? sale.phone : "N/A"}

        p
          strong Address:
          |  #{sale && sale.address ? sale.address : "N/A"}

        p
          strong Date:
          |  #{sale && sale.date ? new Date(sale.date).toLocaleDateString() : "N/A"}

      hr

      // ITEM TABLE
      table
          thead
            tr
              th Item
              th Qty
              th Unit Price
              th Total
          tbody
            tr
              td #{sale.itemName}
              td #{sale.quantity}
              td UGX #{sale.unitPrice}
              td UGX #{sale.quantity * sale.unitPrice}

      hr

      // SUMMARY
      .summary
        p
          strong Transport:
          |  UGX #{sale.transport || 0}

        p.total
          strong GRAND TOTAL:
          |  UGX #{(sale.quantity * sale.unitPrice) + (sale.transport || 0)}

      hr

      // FOOTER
      .footer
        p Thank you for shopping with us!
        p Please come again

      // PRINT BUTTON
      .actions
        button(onclick='window.print()') Print Receipt