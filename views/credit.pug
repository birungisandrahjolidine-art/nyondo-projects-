doctype html
html
  head
    meta(charset='UTF-8')
    title Credit page
    link(rel='stylesheet' href='/css/credit.css')

  body
    .container

      h1 Credit page

      // BUTTON
      .top-bar
        a.btn(href='/creditform') + Add New Sale on credit

      // CARDS (DYNAMIC)
      .cards

        .card
          h2 Total Credit
          p UGX #{totalCredit}

          h2 Total Paid
          p UGX #{totalPaid}

        .card
          h2 People with Credit
          p #{peopleWithCredit}

      // CREDITORS TABLE
      h2.section-title Creditors List

      table
        thead
          tr
            th Creditor Name
            th Phone
            th Item Taken
            th Quantity
            th Unit Price
            th Total cost 
            th amountDeposited 
            th Balance
            th Date Taken
            th Action 

        tbody
          if credits && credits.length > 0
            each credit in credits
              tr
                td #{credit.customerName}
                td #{credit.phoneNumber}
                td #{credit.itemName}
                td #{credit.quantity}
                td #{credit.unitPrice}
                td #{credit.totalCost}
                td #{credit.amountDeposited}
                td #{credit.balance}
                td #{credit.date.toDateString()}
                td.action 
                 a.btn-receipt(href=`/creditreceipt/${credit._id}`) 
                  |Receipt
          else
            tr
              td(colspan='10') No credit records found

      // ITEMS UNDER CREDIT (OPTIONAL SIMPLE VERSION)
      h2.section-title Items Under Credit

      table
        thead
          tr
            th Item Name
            th Quantity

        tbody
          if credits.length > 0
            each credit in credits
              tr
                td #{credit.itemName}
                td #{credit.quantity}
          else
            tr
              td(colspan='2') No items found