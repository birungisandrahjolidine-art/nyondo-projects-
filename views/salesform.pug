doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Sales Registration
    link(rel='stylesheet' href='/css/sales.css')

  body
    .container
      h2 Register New Sale

      form(action="/salesform" method="post")

        // ================= CUSTOMER INFO =================
        .row
          .input-box
            label Customer Name
            input(type='text' name='customerName' required)

        .row
          .input-box
            label Customer Address
            input(type='text' name='customerAddress' required)

          .input-box
            label Customer Distance (KM)
            input(type='number' name='customerDistance' required)

        
        .row
          .input-box
            label Phone Number
            input(
              type='text'
              name='phoneNumber'
              placeholder='+256700123456'
              pattern='^\\+256[0-9]{9}$'
              title='Phone number must start with +256 and contain exactly 9 digits after it'
            )
      

        // ================= ITEMS SECTION =================
        h3 Items Purchased

        #itemsContainer

          .item-row
            .input-box
              label Item
              select(name='items[0][itemId]' required)
                option(value='') Select Item
                each item in stockItems
                  option(value=item._id)
                    = item.itemName + " (Stock: " + item.quantity + ")"

            .input-box
              label Quantity
              input(type='number' name='items[0][quantity]' required)

        button(type='button' onclick='addItem()') + Add Another Item

        // ================= TRANSPORT =================
        .row
          .input-box
            label Transport Type
            select(name='transportType' required)
              option(value='') Select Transport Option
              option(value='own') Use Own Transport (No Charge)
              option(value='hardware') Hardware Provides (Free if Purchase ≥ 500,000 UGX)
              option(value='paid') Pay 30,000 UGX for Hardware Transport

        // ================= PAYMENT =================
        .row
          .input-box
            label Payment Method
            select(name='paymentMethod' required)
              option Cash
              option Mobile Money
              option Bank

        button(type='submit') Submit Sale


    // ================= JAVASCRIPT =================
    script.
      let index = 1;

      const firstSelect = document.querySelector('#itemsContainer .item-row select');
      const itemOptions = firstSelect ? firstSelect.innerHTML : '';

      function addItem() {
        const container = document.getElementById('itemsContainer');

        const div = document.createElement('div');
        div.classList.add('item-row');

        div.innerHTML = `
          <div class="input-box">
            <label>Item</label>
            <select name="items[${index}][itemId]" required>
              <option value="">Select Item</option>
              ${itemOptions}
            </select>
          </div>

          <div class="input-box">
            <label>Quantity</label>
            <input type="number" name="items[${index}][quantity]" required>
          </div>

          <button type="button" onclick="this.parentElement.remove()">Remove</button>
        `;

        container.appendChild(div);
        index++;
      }

