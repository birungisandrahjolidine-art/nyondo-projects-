
doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Stock Inventory | Nyondo Hardware
    link(rel='stylesheet' href='/css/stock.css')
  body
    // Sidebar
    .sidebar
      h2 Store Manager
      nav
        a(href='/stockdashboard') Dashboard
        a(href='/stockregform') Add New Stock
        a.active(href='/stock') Inventory Levels
        a(href='/logout') Logout

    // Main Content
    .main-content
      header
        h1 Current Inventory
        p Overview of available stock 

      // Low Stock Alert Section 
      section.alert-section
        .alert-card
          .alert-header
            span.warning-icon &#x26A0;
            h3 Low Stock Alerts
          ul.alert-list
            if dbStock && dbStock.length > 0
              each stock in dbStock
                if stock.totalQuantity <= 20
                  li
                    strong #{stock._id}: 
                    | Only #{stock.totalQuantity} units left. 
                    span.action-text Reorder soon
            else
              li No alerts

      // Inventory Table
      section.table-section
        .table-card
          table
            thead
              tr
                th Item Image
                th Item Name
                th Quantity
                th Selling Price
                th Supplier       
            tbody
              if dbStock && dbStock.length > 0
                each stock in dbStock 
                  tr
                    td
                      if stock.itemimage
                        img(
                          src='/uploads/' + stock.itemimage,
                          alt='image',
                          width='120px',
                          height='120px',
                          style='object-fit: cover; border-radius: 4px;'
                        )
                      else
                        span No Image
                    td #{stock._id}               
                    td #{stock.totalQuantity}     
                    td UGX #{stock.sellingPrice ? stock.sellingPrice.toLocaleString() : '0'}
                    td #{stock.supplierName ? stock.supplierName : 'N/A'}
              else
                tr
                  td.text-center(colspan='5') No stock has been recorded yet