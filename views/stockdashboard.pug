
doctype html
html
  head
    meta(charset='UTF-8')
    title Hardware Store Dashboard
    link(rel='stylesheet' href='/css/stockdashboard.css')

  body
    .sidebar
      h2 Store Manager
      a(href='/stockregform') Register new stock
      a(href='/index') Home
      a(href='/logout') Logout

    .main
      .top-buttons
        button.btn.orange Register New Stock
        button.btn.blue Register Supplier

      .card.alert
        h3 Stock Alerts
        p ⚠ Cement is running low
        p ⚠ Nails stock below minimum level

      .card
        h3 new stocked items 

        table
          thead
            tr
              th Item Image
              th Item Name
              th Quantity
              th Unit Price
              th Supplier Name
              th Supplier Phone
              th Factory
              th Selling Price
              th Date
              th Payment Status
              th Actions

          tbody
            each stock  in dbStock 
              tr
                td
                  img(
                    src='/uploads/' + stock.itemimage,
                    alt='image',
                    width='120px',
                    height='120px'
                  )

                td #{stock.itemName}
                td #{stock.quantity}
                td #{stock.unitPrice}
                td #{stock.supplierName}
                td #{stock.supplierPhone}
                td #{stock.factory}
                td #{stock.sellingPrice}
                td #{new Date(stock.date).toLocaleDateString()}
                td #{stock.paymentStatus}

                td
                  .d-flex.gap-2
                    a.btn.btn-sm.btn-outline-warning(
                      href=`/stock/edit/${stock._id}`
                    )
                      i.fas.fa-edit

                    form(
                      action=`/delete/${stock._id}`,
                      method='POST',
                      onsubmit='return confirm("Are you sure you want to delete this item?")'
                    )
                      button.btn.btn-sm.btn-outline-danger(type='submit')
                        i.fas.fa-trash-alt

            if dbStock.length === 0
              tr
                td.text-center(colspan='10')
                  | No stock have been recorded yet

      .card
        h3 All Items in stock 

        table
           thead
             tr
                th Item Image
                th Item Name
                th Quantity
                th Factory
                th Selling Price
           tbody
            each stock  in dbStock 
              tr
                td
                  img(
                    src='/uploads/' + stock.itemimage,
                    alt='image',
                    width='120px',
                    height='120px'
                  )

                td #{stock.itemName}
                td #{stock.quantity}
                td #{stock.factory}
                td #{stock.sellingPrice}
                
                