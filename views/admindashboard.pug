
doctype html
html
  head
    meta(charset='UTF-8')
    meta(name='viewport' content='width=device-width, initial-scale=1.0')
    title Admin Dashboard
    link(rel='stylesheet' href='/css/admindashboard.css')

  body

    // SIDEBAR 
    .sidebar
      .sidebar-header
        img.sidebar-logo(src='/images/loggo.png')
        h2 Nyondo Admin

      ul
        li: a(href='/admin') Admin Home
        li: a(href='/salesdashboard') Sales Dashboard
        li: a(href='/stockdashboard') Stock Dashboard
        li: a(href='/credit') Credit
        li: a(href='/reports') Reports
        li: a(href='/logout') Logout
        li: a(href='/index') Home

    // MAIN 
    .main

      .header
        h1 Dashboard Overview
        p Welcome back Admin! Your business summary is here below.

      // CARDS 
      .cards

        .card
          h3 Total Stock
          p #{totalStock ? totalStock.toLocaleString() : '0'} Items

        .card
          h3 Sales Today
          p UGX #{totalSales ? totalSales.toLocaleString() : '0'}

        .card
          h3 Total Credit
          p UGX #{totalCredit ? totalCredit.toLocaleString() : '0'}

        .card
          h3 Total Paid
          p UGX #{totalPaid ? totalPaid.toLocaleString() : '0'}

      // PROFIT 
      .finance
        .finance-box
          h3 📊 Net Profit
          p.income UGX #{profit ? profit.toLocaleString() : '0'}

      // creditors
      .creditors
        h3 🧾 Creditors (customers with credit)

        .creditor-list
          if credits && credits.length > 0
            each credit in credits
              if credit.balance > 0
                .creditor
                  p
                    strong #{credit.customerName}
                  p.debt Owes: UGX #{credit.balance ? credit.balance.toLocaleString() : '0'}
          else
            p No creditors found
      .low-stock
        h3 ⚠ Low Stock Items

        ul
          if dbStock && dbStock.length > 0
            each item in dbStock
              if item.totalQuantity <= 20
                li
                  span.warning #{item._id}:
                  |  Only #{item.totalQuantity} left
          else
            li No stock data
      .stock-table
        h3 📦 Items in Stock

        table
          thead
            tr
              th Item Name
              th Quantity

          tbody
            if dbStock && dbStock.length > 0
              each item in dbStock
                tr
                  td #{item._id}
                  td #{item.totalQuantity}
            else
              tr
                td(colspan='2') No stock available